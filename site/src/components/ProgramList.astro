---
const { programs } = Astro.props;
const platforms = [...new Set(programs.map((program) => program.platform))].sort();

function formatSignal(value) {
  if (value === null || value === undefined) return "unknown";
  if (value >= 4.5) return "excellent";
  if (value >= 3.5) return "good";
  if (value >= 2.5) return "average";
  return "poor";
}

function ratingTone(value) {
  if (!value) return "muted";
  if (value >= 4) return "good";
  if (value >= 3) return "mid";
  return "bad";
}

function ratingSymbol(value) {
  if (!value) return "-";
  if (value >= 4) return "+";
  if (value >= 3) return "=";
  return "-";
}
---

<section class="shell" aria-labelledby="ranking-title">
  <div class="toolbar" data-program-filters>
    <input class="field" type="search" placeholder="Search programs or platforms..." aria-label="Search programs" data-search />
    <select class="field" aria-label="Filter by platform" data-platform>
      <option value="">All platforms</option>
      {platforms.map((platform) => <option value={platform}>{platform}</option>)}
    </select>
    <select class="field" aria-label="Minimum reputation" data-rating>
      <option value="0">Any reputation</option>
      <option value="4">Strong reputation</option>
      <option value="3">Mixed or better</option>
      <option value="2">Include weak</option>
    </select>
    <select class="field" aria-label="Minimum response reliability" data-response>
      <option value="0">Any response</option>
      <option value="3.5">Reliable response</option>
      <option value="2.5">Acceptable response</option>
    </select>
    <select class="field" aria-label="Minimum payment reliability" data-payment>
      <option value="0">Any payment</option>
      <option value="3.5">Reliable payment</option>
      <option value="2.5">Acceptable payment</option>
    </select>
    <select class="field" aria-label="Minimum report handling quality" data-triage>
      <option value="0">Any handling</option>
      <option value="3.5">Clear handling</option>
      <option value="2.5">Acceptable handling</option>
    </select>
    <select class="field" aria-label="Minimum evidence level" data-review-count>
      <option value="0">Any evidence</option>
      <option value="2">2+ reviews</option>
      <option value="3">3+ reviews</option>
    </select>
    <select class="field" aria-label="Sort programs" data-sort>
      <optgroup label="Reputation">
        <option value="rating-desc">Highest reputation</option>
        <option value="rating-asc">Lowest reputation</option>
      </optgroup>
      <optgroup label="Evidence">
        <option value="reviews-desc">Most reviews</option>
        <option value="reviews-asc">Fewest reviews</option>
      </optgroup>
      <optgroup label="Activity">
        <option value="latest-desc">Latest review</option>
        <option value="latest-asc">Oldest review</option>
      </optgroup>
      <optgroup label="Response">
        <option value="response-desc">Fastest response</option>
        <option value="response-asc">Slowest response</option>
      </optgroup>
      <optgroup label="Payment">
        <option value="payment-desc">Most reliable payment</option>
        <option value="payment-asc">Highest payment risk</option>
      </optgroup>
      <optgroup label="Handling">
        <option value="triage-desc">Clearest handling</option>
        <option value="triage-asc">Weakest handling</option>
      </optgroup>
      <optgroup label="Index">
        <option value="name-asc">Name A-Z</option>
        <option value="name-desc">Name Z-A</option>
        <option value="platform-asc">Platform A-Z</option>
        <option value="platform-desc">Platform Z-A</option>
      </optgroup>
    </select>
    <select class="field" aria-label="Programs loaded per click" data-page-size>
      <option value="10">Show 10</option>
      <option value="25">Show 25</option>
      <option value="50">Show 50</option>
    </select>
  </div>

  <div class="program-table" id="ranking-title">
    {
      programs.length === 0 ? (
        <div class="empty">
          No reviews yet. The ranking will appear here after the first accepted program review.
        </div>
      ) : (
        programs.map((program) => (
          <a
            class="program-row"
            href={program.path}
            data-program-row
            data-name={program.name.toLowerCase()}
            data-platform={program.platform}
            data-rating={program.averageRating}
            data-reviews={program.reviewCount}
            data-latest={program.latestReview}
            data-response={program.signals.response_time ?? 0}
            data-payment={program.signals.payment_reliability ?? 0}
            data-triage={program.signals.triage_quality ?? 0}
            data-scope={program.signals.scope_accuracy ?? 0}
            data-communication={program.signals.communication ?? 0}
            data-search={`${program.name} ${program.platform} ${program.slug} ${program.reviews.flatMap((review) => review.tags ?? []).join(" ")}`.toLowerCase()}
          >
            <div>
              <div class="program-name">{program.name}</div>
              <div class="program-url">{program.programUrl}</div>
            </div>
            <span class="badge">{program.platform}</span>
            <div>
              <div class={`rating rating-${ratingTone(program.averageRating)}`}>
                <span aria-hidden="true">{ratingSymbol(program.averageRating)}</span>
                {program.averageRating ? program.averageRating.toFixed(2) : "n/a"}
              </div>
              <div class="muted">{program.reviewCount} reviews</div>
            </div>
            <div class="signal">
              <span>response</span>
              <strong>{formatSignal(program.signals.response_time)}</strong>
            </div>
            <div class="signal">
              <span>payment</span>
              <strong>{formatSignal(program.signals.payment_reliability)}</strong>
            </div>
          </a>
        ))
      )
    }
    <div class="empty" hidden data-empty-results>No programs match the current filters.</div>
  </div>

  <div class="ranking-footer" data-ranking-footer hidden>
    <span data-page-status></span>
    <div class="pager">
      <button class="button button-secondary" type="button" data-more-programs>More</button>
    </div>
  </div>
</section>

<script>
  const filterRoot = document.querySelector("[data-program-filters]");
  const rows = [...document.querySelectorAll("[data-program-row]")];
  const empty = document.querySelector("[data-empty-results]");
  const table = document.querySelector(".program-table");
  const footer = document.querySelector("[data-ranking-footer]");
  const status = document.querySelector("[data-page-status]");
  const more = document.querySelector("[data-more-programs]");
  let visibleCount = 10;

  function numeric(row, key) {
    return Number(row.dataset[key] ?? 0);
  }

  function byName(a, b) {
    return a.dataset.name.localeCompare(b.dataset.name);
  }

  function compareSignal(a, b, key, direction) {
    return direction * (numeric(b, key) - numeric(a, key))
      || Number(b.dataset.reviews ?? 0) - Number(a.dataset.reviews ?? 0)
      || byName(a, b);
  }

  function sortRows(items, mode) {
    const sorted = [...items];
    sorted.sort((a, b) => {
      if (mode === "rating-asc") {
        return Number(a.dataset.rating ?? 0) - Number(b.dataset.rating ?? 0)
          || Number(b.dataset.reviews ?? 0) - Number(a.dataset.reviews ?? 0)
          || byName(a, b);
      }
      if (mode === "reviews-desc") {
        return Number(b.dataset.reviews ?? 0) - Number(a.dataset.reviews ?? 0)
          || Number(b.dataset.rating ?? 0) - Number(a.dataset.rating ?? 0)
          || byName(a, b);
      }
      if (mode === "reviews-asc") {
        return Number(a.dataset.reviews ?? 0) - Number(b.dataset.reviews ?? 0)
          || Number(b.dataset.rating ?? 0) - Number(a.dataset.rating ?? 0)
          || byName(a, b);
      }
      if (mode === "latest-desc") {
        return String(b.dataset.latest ?? "").localeCompare(String(a.dataset.latest ?? ""))
          || Number(b.dataset.rating ?? 0) - Number(a.dataset.rating ?? 0)
          || byName(a, b);
      }
      if (mode === "latest-asc") {
        return String(a.dataset.latest ?? "").localeCompare(String(b.dataset.latest ?? ""))
          || Number(b.dataset.rating ?? 0) - Number(a.dataset.rating ?? 0)
          || byName(a, b);
      }
      if (mode === "response-desc") {
        return compareSignal(a, b, "response", 1);
      }
      if (mode === "response-asc") {
        return compareSignal(a, b, "response", -1);
      }
      if (mode === "payment-desc") {
        return compareSignal(a, b, "payment", 1);
      }
      if (mode === "payment-asc") {
        return compareSignal(a, b, "payment", -1);
      }
      if (mode === "triage-desc") {
        return compareSignal(a, b, "triage", 1);
      }
      if (mode === "triage-asc") {
        return compareSignal(a, b, "triage", -1);
      }
      if (mode === "name-asc") {
        return byName(a, b);
      }
      if (mode === "name-desc") {
        return byName(b, a);
      }
      if (mode === "platform-asc") {
        return a.dataset.platform.localeCompare(b.dataset.platform)
          || byName(a, b);
      }
      if (mode === "platform-desc") {
        return b.dataset.platform.localeCompare(a.dataset.platform)
          || byName(a, b);
      }
      return Number(b.dataset.rating ?? 0) - Number(a.dataset.rating ?? 0)
        || Number(b.dataset.reviews ?? 0) - Number(a.dataset.reviews ?? 0)
        || byName(a, b);
    });
    return sorted;
  }

  function render(resetPage = false) {
    const query = filterRoot?.querySelector("[data-search]")?.value?.toLowerCase().trim() ?? "";
    const platform = filterRoot?.querySelector("[data-platform]")?.value ?? "";
    const minRating = Number(filterRoot?.querySelector("[data-rating]")?.value ?? 0);
    const minResponse = Number(filterRoot?.querySelector("[data-response]")?.value ?? 0);
    const minPayment = Number(filterRoot?.querySelector("[data-payment]")?.value ?? 0);
    const minTriage = Number(filterRoot?.querySelector("[data-triage]")?.value ?? 0);
    const minReviews = Number(filterRoot?.querySelector("[data-review-count]")?.value ?? 0);
    const sortMode = filterRoot?.querySelector("[data-sort]")?.value ?? "rating-desc";
    const pageSize = Number(filterRoot?.querySelector("[data-page-size]")?.value ?? 10);
    if (resetPage) visibleCount = pageSize;
    visibleCount = Math.max(pageSize, visibleCount);
    const filtered = rows.filter((row) => {
      const matchesQuery = !query || row.dataset.search?.includes(query);
      const matchesPlatform = !platform || row.dataset.platform === platform;
      const matchesRating = Number(row.dataset.rating ?? 0) >= minRating;
      const matchesResponse = Number(row.dataset.response ?? 0) >= minResponse;
      const matchesPayment = Number(row.dataset.payment ?? 0) >= minPayment;
      const matchesTriage = Number(row.dataset.triage ?? 0) >= minTriage;
      const matchesReviews = Number(row.dataset.reviews ?? 0) >= minReviews;
      return matchesQuery
        && matchesPlatform
        && matchesRating
        && matchesResponse
        && matchesPayment
        && matchesTriage
        && matchesReviews;
    });
    const sorted = sortRows(filtered, sortMode);
    visibleCount = Math.min(visibleCount, sorted.length || pageSize);
    const visibleRows = sorted.slice(0, visibleCount);
    const pageRows = new Set(visibleRows);

    for (const row of sorted) {
      table?.insertBefore(row, empty);
    }
    for (const row of rows) {
      row.hidden = !pageRows.has(row);
      row.classList.toggle("is-hidden", !pageRows.has(row));
    }

    if (empty) empty.hidden = sorted.length !== 0 || rows.length === 0;
    if (footer) footer.hidden = sorted.length === 0;
    if (status) {
      status.textContent = sorted.length
        ? `${visibleRows.length} of ${sorted.length} programs`
        : "0 programs";
    }
    if (more) more.hidden = visibleRows.length >= sorted.length;
  }

  filterRoot?.addEventListener("input", () => render(true));
  filterRoot?.addEventListener("change", () => render(true));
  more?.addEventListener("click", () => {
    const pageSize = Number(filterRoot?.querySelector("[data-page-size]")?.value ?? 10);
    visibleCount += pageSize;
    render();
  });
  render();
</script>
