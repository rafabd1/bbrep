---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProgramList from "../components/ProgramList.astro";
import data from "../generated/programs.json";

const programs = data.programs;
const reviewCount = programs.reduce((sum, program) => sum + program.reviewCount, 0);
const platformCount = new Set(programs.map((program) => program.platform)).size;
---

<BaseLayout title="bbrep | Bug bounty program reputation">
  <section class="shell hero">
    <div>
      <p class="lede">
        Structured researcher reviews for public BBP and VDP programs.
      </p>
    </div>
    <div class="stat-strip" aria-label="Repository stats">
      <div class="stat">
        <strong>{programs.length}</strong>
        <span>programs</span>
      </div>
      <div class="stat">
        <strong>{reviewCount}</strong>
        <span>reviews</span>
      </div>
      <div class="stat">
        <strong>{platformCount}</strong>
        <span>platforms</span>
      </div>
    </div>
  </section>

  <ProgramList programs={programs} />
</BaseLayout>
