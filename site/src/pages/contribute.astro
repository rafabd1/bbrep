---
import BaseLayout from "../layouts/BaseLayout.astro";
import data from "../generated/programs.json";

const knownPrograms = data.programs.map((program) => ({
  key: `${program.platform}/${program.slug}`,
  name: program.name,
  platform: program.platform,
  slug: program.slug,
}));
const knownPlatforms = [
  "hackerone",
  "bugcrowd",
  "intigriti",
  "yeswehack",
  "immunefi",
  "code4rena",
  "sherlock",
  "cantina",
  "hackenproof",
  "hats",
  "codehawks",
  "self-hosted",
];
---

<BaseLayout title="Contribute | bbrep">
  <section class="shell content contribute-page">
    <div class="contribute-head">
      <p class="eyebrow">Contribute</p>
      <h1>Submit a program review</h1>
      <p class="lede">
        Fill the fields, copy the generated Issue body, and create a GitHub Issue
        with the review-submission label.
      </p>
    </div>

    <section class="submission-actions" aria-label="Submission options">
      <a class="button" href="https://github.com/rafabd1/bbrep/issues/new?labels=review-submission&title=Review:%20" data-create-issue>Create Issue</a>
    </section>

    <section class="generator" data-review-generator data-known-programs={JSON.stringify(knownPrograms)}>
      <form class="generator-form">
        <label class="wide">
          Program name
          <input class="field" name="programName" placeholder="Example Security Program" required />
        </label>
        <label>
          Platform
          <input class="field" name="platform" list="platform-options" placeholder="hackerone, self-hosted, or custom-platform" required />
          <datalist id="platform-options">
            {knownPlatforms.map((platform) => <option value={platform} />)}
          </datalist>
        </label>
        <label>
          Program URL
          <input class="field" name="programUrl" type="url" pattern="https://.*" title="Use an https URL." placeholder="https://example.com/security" required />
        </label>
        <label>
          Display on site
          <select class="field" name="display" required>
            <option value="github">show GitHub handle</option>
            <option value="anonymous">anonymous</option>
          </select>
        </label>
        <label>
          Experience month
          <input class="field" name="experienceDate" type="month" required />
        </label>
        <label>
          Overall rating
          <select class="field" name="rating" required>
            <option value="5">5</option>
            <option value="4" selected>4</option>
            <option value="3">3</option>
            <option value="2">2</option>
            <option value="1">1</option>
          </select>
        </label>
        <label>
          Response time
          <select class="field" name="responseTime" required>
            <option value="fast">fast</option>
            <option value="medium" selected>medium</option>
            <option value="slow">slow</option>
            <option value="ghosted">ghosted</option>
            <option value="unknown">unknown</option>
          </select>
        </label>
        <label>
          Triage quality
          <select class="field" name="triageQuality" required>
            <option value="excellent">excellent</option>
            <option value="good" selected>good</option>
            <option value="average">average</option>
            <option value="poor">poor</option>
            <option value="unknown">unknown</option>
          </select>
        </label>
        <label>
          Payment reliability
          <select class="field" name="paymentReliability" required>
            <option value="excellent">excellent</option>
            <option value="good" selected>good</option>
            <option value="average">average</option>
            <option value="poor">poor</option>
            <option value="unpaid">unpaid</option>
            <option value="not-applicable">not-applicable</option>
            <option value="unknown">unknown</option>
          </select>
        </label>
        <label>
          Scope accuracy
          <select class="field" name="scopeAccuracy" required>
            <option value="excellent">excellent</option>
            <option value="good" selected>good</option>
            <option value="average">average</option>
            <option value="poor">poor</option>
            <option value="unknown">unknown</option>
          </select>
        </label>
        <label>
          Communication
          <select class="field" name="communication" required>
            <option value="excellent">excellent</option>
            <option value="good" selected>good</option>
            <option value="average">average</option>
            <option value="poor">poor</option>
            <option value="none">none</option>
            <option value="unknown">unknown</option>
          </select>
        </label>
        <label class="wide">
          Public note
          <textarea class="field textarea" name="note" maxlength="500" placeholder="Keep it factual, public, and disclosure-safe."></textarea>
        </label>
      </form>

      <aside class="generator-output" aria-live="polite">
        <div class="output-meta">
          <span class="pill" data-program-state>New program</span>
          <code data-output-title>Review: Example Security Program</code>
        </div>
        <p class="muted" data-output-instructions>
          Copy this body into a GitHub Issue and keep the review-submission label.
        </p>
        <div class="output-actions">
          <button class="button button-secondary" type="button" data-copy-issue>Copy Issue Body</button>
          <span class="copy-status" data-copy-status></span>
        </div>
        <pre class="code-block"><code data-output-issue></code></pre>
      </aside>
    </section>
  </section>
</BaseLayout>

<script>
  const root = document.querySelector("[data-review-generator]");
  const form = root?.querySelector("form");
  const outputTitle = root?.querySelector("[data-output-title]");
  const outputIssue = root?.querySelector("[data-output-issue]");
  const outputState = root?.querySelector("[data-program-state]");
  const outputInstructions = root?.querySelector("[data-output-instructions]");
  const copyButton = root?.querySelector("[data-copy-issue]");
  const copyStatus = root?.querySelector("[data-copy-status]");
  const createIssueLink = document.querySelector("[data-create-issue]");
  const knownPrograms = JSON.parse(root?.getAttribute("data-known-programs") || "[]");
  const knownProgramKeys = new Set(knownPrograms.map((program) => program.key));

  const thisMonth = new Date().toISOString().slice(0, 7);

  function value(name, fallback = "") {
    return form?.querySelector(`[name="${name}"]`)?.value?.trim() || fallback;
  }

  function slugify(input) {
    return input
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-+|-+$/g, "")
      .replace(/-{2,}/g, "-") || "program-slug";
  }

  function platformSlug(input) {
    return slugify(input || "self-hosted");
  }

  function inferPlatform(url) {
    const normalized = url.toLowerCase();
    if (normalized.includes("hackerone.com/")) return "hackerone";
    if (normalized.includes("bugcrowd.com/")) return "bugcrowd";
    if (normalized.includes("intigriti.com/programs/")) return "intigriti";
    if (normalized.includes("yeswehack.com/programs/")) return "yeswehack";
    if (normalized.includes("immunefi.com/bug-bounty/")) return "immunefi";
    if (normalized.includes("code4rena.com/")) return "code4rena";
    if (normalized.includes("sherlock.xyz/")) return "sherlock";
    if (normalized.includes("cantina.xyz/")) return "cantina";
    if (normalized.includes("hackenproof.com/")) return "hackenproof";
    if (normalized.includes("hats.finance/")) return "hats";
    if (normalized.includes("codehawks.com/")) return "codehawks";
    return "";
  }

  function findExistingProgram(platform, slug, name) {
    const key = `${platform}/${slug}`;
    const direct = knownPrograms.find((program) => program.key === key);
    if (direct) return direct;

    const normalizedName = slugify(name);
    return knownPrograms.find((program) => program.slug === normalizedName) || null;
  }

  function buildIssueBody(programName, platform, programUrl) {
    return `### Program name
${programName}

### Platform
${platform}

### Program URL
${programUrl}

### Display on site
${value("display", "github")}

### Experience month
${value("experienceDate", thisMonth)}

### Overall rating
${value("rating", "4")}

### Response time
${value("responseTime", "medium")}

### Triage quality
${value("triageQuality", "good")}

### Payment reliability
${value("paymentReliability", "good")}

### Scope accuracy
${value("scopeAccuracy", "good")}

### Communication
${value("communication", "good")}

### Public note
${value("note", "")}`;
  }

  function updateOutput() {
    const programName = value("programName", "Example Security Program");
    const programUrl = value("programUrl", "https://example.com/security");
    const inferred = inferPlatform(programUrl);
    const platformField = form?.querySelector('[name="platform"]');
    if (inferred && platformField && !platformField.dataset.userChanged && !platformField.value.trim()) {
      platformField.value = inferred;
    }

    const platform = platformSlug(value("platform", "self-hosted"));
    const slug = slugify(programName);
    const existing = findExistingProgram(platform, slug, programName);
    const exists = Boolean(existing) || knownProgramKeys.has(`${platform}/${slug}`);
    const issueTitle = `Review: ${programName}`;

    if (outputTitle) outputTitle.textContent = issueTitle;
    if (outputIssue) outputIssue.textContent = buildIssueBody(programName, platform, programUrl);
    if (createIssueLink) {
      const params = new URLSearchParams({
        labels: "review-submission",
        title: issueTitle,
      });
      createIssueLink.href = `https://github.com/rafabd1/bbrep/issues/new?${params.toString()}`;
    }
    if (outputState) outputState.textContent = exists ? "Existing program" : "New program";
    if (outputInstructions) {
      outputInstructions.textContent = `Copy this body into an Issue titled "${issueTitle}" and keep the review-submission label.`;
    }
  }

  form?.addEventListener("input", updateOutput);
  form?.addEventListener("change", updateOutput);
  form?.querySelector('[name="platform"]')?.addEventListener("input", (event) => {
    event.currentTarget.dataset.userChanged = "true";
    const current = event.currentTarget.value;
    const normalized = platformSlug(current);
    if (current && current !== normalized && /[^a-z0-9-]/.test(current)) {
      event.currentTarget.value = normalized;
    }
  });

  const experienceField = form?.querySelector('[name="experienceDate"]');
  if (experienceField) {
    experienceField.value = thisMonth;
  }
  const platformField = form?.querySelector('[name="platform"]');
  if (platformField && !platformField.value) {
    platformField.value = "self-hosted";
  }

  copyButton?.addEventListener("click", async () => {
    if (form && !form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const text = outputIssue?.textContent || "";
    if (!text) return;
    let copied = false;
    try {
      await navigator.clipboard.writeText(text);
      copied = true;
    } catch {
      const textarea = document.createElement("textarea");
      textarea.value = text;
      textarea.setAttribute("readonly", "");
      textarea.style.position = "fixed";
      textarea.style.opacity = "0";
      document.body.append(textarea);
      textarea.select();
      copied = document.execCommand("copy");
      textarea.remove();
    }
    if (copyStatus) {
      copyStatus.textContent = copied ? "Copied" : "Copy failed";
      window.setTimeout(() => {
        copyStatus.textContent = "";
      }, 1800);
    }
  });

  updateOutput();
</script>
