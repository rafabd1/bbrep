---
import BaseLayout from "../layouts/BaseLayout.astro";
import data from "../generated/programs.json";

const knownPrograms = data.programs.map((program) => `${program.platform}/${program.slug}`);
---

<BaseLayout title="Contribute | bbrep">
  <section class="shell content contribute-page">
    <div class="contribute-head">
      <p class="eyebrow">Contribute</p>
      <h1>Submit a program review</h1>
      <p class="lede">
        Fill the form, copy the generated YAML, and open a Pull Request. The site
        updates automatically after the PR is reviewed and merged.
      </p>
    </div>

    <section class="submission-steps" aria-labelledby="steps-title">
      <h2 id="steps-title">How submission works</h2>
      <ol>
        <li>Generate the YAML below.</li>
        <li>Open a Pull Request in <a href="https://github.com/rafabd1/bbrep">rafabd1/bbrep</a>.</li>
        <li>If the program is new, create the generated file path.</li>
        <li>If the program exists, edit that file and update your own review or append a new one.</li>
        <li>Wait for CI and maintainer review.</li>
      </ol>
      <p>
        Deduplication uses <strong>program + GitHub PR author</strong>. Choosing anonymous only
        hides your handle on the site; GitHub history still shows the PR author.
      </p>
    </section>

    <section class="generator" data-review-generator data-known-programs={JSON.stringify(knownPrograms)}>
      <form class="generator-form">
        <label class="wide">
          Program name
          <input class="field" name="programName" placeholder="Example Security Program" required />
        </label>
        <label>
          Platform
          <select class="field" name="platform">
            <option value="hackerone">hackerone</option>
            <option value="bugcrowd">bugcrowd</option>
            <option value="intigriti">intigriti</option>
            <option value="yeswehack">yeswehack</option>
            <option value="immunefi">immunefi</option>
            <option value="code4rena">code4rena</option>
            <option value="sherlock">sherlock</option>
            <option value="cantina">cantina</option>
            <option value="hackenproof">hackenproof</option>
            <option value="hats">hats</option>
            <option value="codehawks">codehawks</option>
            <option value="self-hosted" selected>self-hosted</option>
            <option value="other">other</option>
          </select>
        </label>
        <label>
          Program URL
          <input class="field" name="programUrl" type="url" placeholder="https://example.com/security" required />
        </label>
        <label>
          Your GitHub handle
          <input class="field" name="github" placeholder="octocat" required />
        </label>
        <label>
          Display on site
          <select class="field" name="display">
            <option value="github">show GitHub handle</option>
            <option value="anonymous">anonymous</option>
          </select>
        </label>
        <label>
          Experience month
          <input class="field" name="experienceDate" type="month" required />
        </label>
        <label>
          Overall rating
          <select class="field" name="rating">
            <option value="5">5</option>
            <option value="4" selected>4</option>
            <option value="3">3</option>
            <option value="2">2</option>
            <option value="1">1</option>
          </select>
        </label>
        <label>
          Response time
          <select class="field" name="responseTime">
            <option value="fast">fast</option>
            <option value="medium" selected>medium</option>
            <option value="slow">slow</option>
            <option value="ghosted">ghosted</option>
            <option value="unknown">unknown</option>
          </select>
        </label>
        <label>
          Triage quality
          <select class="field" name="triageQuality">
            <option value="excellent">excellent</option>
            <option value="good" selected>good</option>
            <option value="average">average</option>
            <option value="poor">poor</option>
            <option value="unknown">unknown</option>
          </select>
        </label>
        <label>
          Payment reliability
          <select class="field" name="paymentReliability">
            <option value="excellent">excellent</option>
            <option value="good" selected>good</option>
            <option value="average">average</option>
            <option value="poor">poor</option>
            <option value="unpaid">unpaid</option>
            <option value="not-applicable">not-applicable</option>
            <option value="unknown">unknown</option>
          </select>
        </label>
        <label>
          Scope accuracy
          <select class="field" name="scopeAccuracy">
            <option value="excellent">excellent</option>
            <option value="good" selected>good</option>
            <option value="average">average</option>
            <option value="poor">poor</option>
            <option value="unknown">unknown</option>
          </select>
        </label>
        <label>
          Communication
          <select class="field" name="communication">
            <option value="excellent">excellent</option>
            <option value="good" selected>good</option>
            <option value="average">average</option>
            <option value="poor">poor</option>
            <option value="none">none</option>
            <option value="unknown">unknown</option>
          </select>
        </label>
        <label class="wide">
          Public note
          <textarea class="field textarea" name="note" maxlength="500" placeholder="Keep it factual, public, and disclosure-safe."></textarea>
        </label>
      </form>

      <aside class="generator-output" aria-live="polite">
        <div class="output-meta">
          <span class="pill" data-program-state>New program</span>
          <code data-output-path>data/programs/self-hosted/example-security-program.yml</code>
        </div>
        <p class="muted" data-output-instructions>
          Create this file in your PR. The program page will be generated after merge.
        </p>
        <div class="output-actions">
          <a class="button" href="https://github.com/rafabd1/bbrep/pulls" data-pr-link>Open PR</a>
          <button class="button button-secondary" type="button" data-copy-yaml>Copy YAML</button>
          <span class="copy-status" data-copy-status></span>
        </div>
        <pre class="code-block"><code data-output-yaml></code></pre>
      </aside>
    </section>
  </section>
</BaseLayout>

<script>
  const root = document.querySelector("[data-review-generator]");
  const form = root?.querySelector("form");
  const outputPath = root?.querySelector("[data-output-path]");
  const outputYaml = root?.querySelector("[data-output-yaml]");
  const outputState = root?.querySelector("[data-program-state]");
  const outputInstructions = root?.querySelector("[data-output-instructions]");
  const copyButton = root?.querySelector("[data-copy-yaml]");
  const copyStatus = root?.querySelector("[data-copy-status]");
  const knownPrograms = new Set(JSON.parse(root?.getAttribute("data-known-programs") || "[]"));

  const today = new Date().toISOString().slice(0, 10);
  const thisMonth = today.slice(0, 7);

  function value(name, fallback = "") {
    return form?.querySelector(`[name="${name}"]`)?.value?.trim() || fallback;
  }

  function slugify(input) {
    return input
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-+|-+$/g, "")
      .replace(/-{2,}/g, "-") || "program-slug";
  }

  function yamlString(input) {
    return JSON.stringify(input || "");
  }

  function inferPlatform(url) {
    const normalized = url.toLowerCase();
    if (normalized.includes("hackerone.com/")) return "hackerone";
    if (normalized.includes("bugcrowd.com/")) return "bugcrowd";
    if (normalized.includes("intigriti.com/programs/")) return "intigriti";
    if (normalized.includes("yeswehack.com/programs/")) return "yeswehack";
    if (normalized.includes("immunefi.com/bug-bounty/")) return "immunefi";
    if (normalized.includes("code4rena.com/")) return "code4rena";
    if (normalized.includes("sherlock.xyz/")) return "sherlock";
    if (normalized.includes("cantina.xyz/")) return "cantina";
    if (normalized.includes("hackenproof.com/")) return "hackenproof";
    if (normalized.includes("hats.finance/")) return "hats";
    if (normalized.includes("codehawks.com/")) return "codehawks";
    return "";
  }

  function buildReviewYaml(indent = "  - ") {
    const note = value("note");
    return `${indent}reviewer:
      github: ${slugify(value("github", "octocat"))}
      display: ${value("display", "github")}
    experience_date: ${yamlString(value("experienceDate", thisMonth))}
    submitted_at: ${yamlString(today)}
    rating: ${value("rating", "4")}
    response_time: ${value("responseTime", "medium")}
    triage_quality: ${value("triageQuality", "good")}
    payment_reliability: ${value("paymentReliability", "good")}
    scope_accuracy: ${value("scopeAccuracy", "good")}
    communication: ${value("communication", "good")}${note ? `\n    note: ${yamlString(note)}` : ""}`;
  }

  function updateOutput() {
    const programName = value("programName", "Example Security Program");
    const programUrl = value("programUrl", "https://example.com/security");
    const inferred = inferPlatform(programUrl);
    const platformField = form?.querySelector('[name="platform"]');
    if (inferred && platformField && !platformField.dataset.userChanged) {
      platformField.value = inferred;
    }

    const platform = value("platform", "self-hosted");
    const slug = slugify(programName);
    const key = `${platform}/${slug}`;
    const path = `data/programs/${key}.yml`;
    const exists = knownPrograms.has(key);

    const fullYaml = `schema_version: 1
program:
  name: ${yamlString(programName)}
  platform: ${platform}
  slug: ${slug}
  program_url: ${yamlString(programUrl)}

reviews:
${buildReviewYaml()}`;

    const reviewOnly = `# In ${path}, update your existing review or append this item under reviews:
${buildReviewYaml()}`;

    if (outputPath) outputPath.textContent = path;
    if (outputYaml) outputYaml.textContent = exists ? reviewOnly : fullYaml;
    if (outputState) outputState.textContent = exists ? "Existing program" : "New program";
    if (outputInstructions) {
      outputInstructions.textContent = exists
        ? "This program already exists. Edit the file below and update your own review if present; otherwise append this item under reviews."
        : "Create this file in your PR. The program page will be generated after merge.";
    }
  }

  form?.addEventListener("input", updateOutput);
  form?.addEventListener("change", updateOutput);
  form?.querySelector('[name="platform"]')?.addEventListener("change", (event) => {
    event.currentTarget.dataset.userChanged = "true";
  });

  const experienceField = form?.querySelector('[name="experienceDate"]');
  if (experienceField) {
    experienceField.value = thisMonth;
  }

  copyButton?.addEventListener("click", async () => {
    const text = outputYaml?.textContent || "";
    if (!text) return;
    let copied = false;
    try {
      await navigator.clipboard.writeText(text);
      copied = true;
    } catch {
      const textarea = document.createElement("textarea");
      textarea.value = text;
      textarea.setAttribute("readonly", "");
      textarea.style.position = "fixed";
      textarea.style.opacity = "0";
      document.body.append(textarea);
      textarea.select();
      copied = document.execCommand("copy");
      textarea.remove();
    }
    if (copyStatus) {
      copyStatus.textContent = copied ? "Copied" : "Copy failed";
      window.setTimeout(() => {
        copyStatus.textContent = "";
      }, 1800);
    }
  });

  updateOutput();
</script>
