---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import data from "../../../generated/programs.json";

export function getStaticPaths() {
  return data.programs.map((program) => ({
    params: { platform: program.platform, slug: program.slug },
    props: { program },
  }));
}

const { program } = Astro.props;

function ratingTone(value) {
  if (!value) return "muted";
  if (value >= 4) return "good";
  if (value >= 3) return "mid";
  return "bad";
}

function ratingSymbol(value) {
  if (!value) return "-";
  if (value >= 4) return "+";
  if (value >= 3) return "=";
  return "-";
}

function reactionLabel(tag) {
  return `${tag.label} ${tag.count ?? 1}x`;
}
---

<BaseLayout title={`${program.name} | bbrep`}>
  <section class="program-header">
    <div class="shell">
      <p class="eyebrow">{program.platform}</p>
      <h1>{program.name}</h1>
      <div class="program-meta">
        <span class={`pill rating rating-${ratingTone(program.averageRating)}`}>
          <span aria-hidden="true">{ratingSymbol(program.averageRating)}</span>
          rating {program.averageRating ? program.averageRating.toFixed(2) : "n/a"}
        </span>
        <span class="pill">{program.reviewCount} reviews</span>
        {program.latestReview && <span class="pill">updated {program.latestReview}</span>}
        <a class="pill" href={program.programUrl}>program</a>
        {program.policyUrl && <a class="pill" href={program.policyUrl}>policy</a>}
      </div>
      {
        program.problemStats.length > 0 && (
          <div class="reaction-row program-header-reactions" aria-label="Known problem tags">
            {program.problemStats.map((tag) => (
              <span class="reaction" title={reactionLabel(tag)} aria-label={reactionLabel(tag)}>
                <span class="reaction-icon" aria-hidden="true">{tag.emoji}</span>
                <span class="reaction-count">{tag.count}x</span>
              </span>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <section class="shell content">
    <h2>Reviews</h2>
    <div class="reviews">
      {
        program.reviews.map((review) => (
          <article class="review">
            <div class="review-top">
              <strong>{review.reviewerLabel}</strong>
              <span class="muted">submitted {review.submitted_at}</span>
            </div>
            <div class="review-grid">
              <span class={`pill rating rating-${ratingTone(review.rating)}`}>
                <span aria-hidden="true">{ratingSymbol(review.rating)}</span>
                rating {review.rating}/5
              </span>
              <span class="pill">response {review.response_time}</span>
              <span class="pill">triage {review.triage_quality}</span>
              <span class="pill">payment {review.payment_reliability}</span>
              <span class="pill">scope {review.scope_accuracy}</span>
            </div>
            {
              review.note && (
                <p class="review-note">
                  {(review.noteParts?.length ? review.noteParts : [{ type: "text", value: review.note }]).map((part) =>
                    part.type === "tag" ? (
                      <>
                        <span class="note-tag">{part.value}</span>{" "}
                        <span class="note-tag-emoji" title={part.label} aria-label={part.label}>{part.emoji}</span>
                      </>
                    ) : (
                      part.value
                    )
                  )}
                </p>
              )
            }
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
